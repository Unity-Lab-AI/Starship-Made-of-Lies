# SMoL Local Self-Host — Caddy Reverse Proxy
#
# Listens on localhost:8080 — Cloudflare Tunnel terminates HTTPS upstream + tunnels
# encrypted requests to this address from smol.unityailab.com.
#
# DEV MODE (default — proxies / to Vite at :5173 for hot-reload):
#   1. start-smol.bat fires all three terminals
#   2. Public URL serves live Vite dev bundle with HMR
#
# PROD MODE (switch to serving client/dist/ static build):
#   1. Run `cd client; corepack pnpm build` to generate client/dist/
#   2. Comment out the DEV block below
#   3. Uncomment the PROD block
#   4. Reload Caddy
#
# Routes (both modes):
#   /ws*       → Colyseus multiplayer server (port 2567)
#   /api/*     → Local Node.js telemetry/auth endpoints (port 3001) — once #3 ships
#   /          → DEV: Vite dev server (:5173) | PROD: client/dist/ static bundle

:8080 {
	# Multiplayer WebSocket — Colyseus on 2567
	handle /ws* {
		reverse_proxy localhost:2567
	}

	# Local API (telemetry / auth / etc.) — Node.js on 3001 (PHASE 11+14 #3 wire-up)
	handle /api/* {
		reverse_proxy localhost:3001
	}

	# === DEV MODE (default) — proxy / to Vite dev server ===
	handle {
		reverse_proxy localhost:5173 {
			# Vite HMR uses WebSocket on the same port
			header_up Host {host}
			header_up X-Real-IP {remote}
		}
	}

	# === PROD MODE (commented out by default) — serve static client/dist/ ===
	# To enable: comment out the DEV handle above, uncomment this block,
	# and make sure `pnpm build` has produced client/dist/.
	#
	# handle {
	# 	root * C:/Users/gfour/Desktop/Starship Made of Lies/client/dist
	# 	try_files {path} /index.html
	# 	file_server
	#
	# 	@hashed {
	# 		path /chunks/* /entries/* /assets/index-* /assets/ui-panels-*
	# 	}
	# 	header @hashed Cache-Control "public, max-age=31536000, immutable"
	#
	# 	@html {
	# 		path /index.html /
	# 	}
	# 	header @html Cache-Control "no-cache, must-revalidate"
	#
	# 	@sw {
	# 		path /sw.js
	# 	}
	# 	header @sw Cache-Control "no-store"
	# }

	# Compress everything text-y
	encode zstd gzip

	# Don't leak server header
	header -Server
}
