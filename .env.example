# Starship Made of Lies — environment template
# Copy this file to `.env.local` (gitignored) and fill in the real values.
# Never commit `.env.local`. Never paste real secrets into this template.

# ============================================================
# Google OAuth 2.0 (PHASE 17.0)
# ============================================================
# Get these from Google Cloud Console → APIs & Services → Credentials
# Walkthrough: see the PHASE 17.0 sign-in setup instructions Claude
# provided in-chat OR Google's docs at:
#   https://developers.google.com/identity/protocols/oauth2/web-server

# Client-side (Vite must see the VITE_ prefix to expose to the browser):
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Server-side (no prefix — only accessible to the Colyseus server process):
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback

# For production / smol.unityailab.com deployment, override redirect URI:
# GOOGLE_OAUTH_REDIRECT_URI=https://smol.unityailab.com/auth/google/callback

# ============================================================
# Server base URL for client → server auth handshake (optional)
# ============================================================
# When client and server are on the same origin (Caddy reverse-proxy), leave
# blank — client calls /api/auth/google/callback on the same origin.
# Override for split deployments:
# VITE_SMOL_SERVER_BASE_URL=https://api.smol.unityailab.com/api/auth/google/callback

# ============================================================
# Future OAuth providers (PHASE 17.0 follow-up)
# ============================================================
# DISCORD_OAUTH_CLIENT_ID=
# DISCORD_OAUTH_CLIENT_SECRET=
# APPLE_OAUTH_CLIENT_ID=
# APPLE_OAUTH_TEAM_ID=
# APPLE_OAUTH_KEY_ID=
# APPLE_OAUTH_PRIVATE_KEY=
